# OpenCode Fleet Lite Configuration

# LLM Provider: anthropic / openai / openrouter / ollama
OPENCODE_PROVIDER=anthropic

# API key for your provider
OPENCODE_API_KEY=sk-your-key-here

# Model to use (provider/model format)
OPENCODE_MODEL=anthropic/claude-sonnet-4

# Telegram bridge (optional -- leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Fleet directory (auto-detected by scripts -- override only if needed)
# FLEET_DIR=/path/to/opencode-fleet-lite
