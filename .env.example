# OpenCode Fleet Lite — template for .env
# ./start.sh copies this to .env automatically if .env is missing (you do not run cp by hand).
# Model / provider: use your normal OpenCode configuration (nothing required here for the LLM).

# Telegram — optional; fill only when you want the bridge
# TELEGRAM_BOT_TOKEN=   from @BotFather
# TELEGRAM_CHAT_ID=     numeric chat id allowed to talk to the bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
